---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const sessions = await getCollection('sessions');
  return sessions
    .filter(s => !s.data.link) // skip sessions with custom links (e.g. vscode-copilot served from public/)
    .map(session => ({
      params: { slug: session.id },
      props: { session },
    }));
}

const { session } = Astro.props;
const { Content } = await render(session);
---
<BaseLayout title={session.data.title} activeNav="sessions">

<main class="container">
  <section class="page-section">

    <!-- Banner -->
    <div style={`padding:48px 32px;border-radius:var(--radius);margin-bottom:32px;background:${session.data.bannerGradient || 'linear-gradient(135deg, var(--accent), var(--purple))'};`}>
      <a href="/sessions" style="color:rgba(255,255,255,0.7);text-decoration:none;font-size:0.85rem;display:inline-block;margin-bottom:12px;">← Back to Sessions</a>
      <h1 style="font-size:1.8rem;font-weight:800;color:#fff;margin:0 0 12px;">{session.data.title}</h1>
      <p style="color:rgba(255,255,255,0.85);font-size:1rem;margin:0 0 16px;max-width:700px;">{session.data.description}</p>
      <div style="display:flex;gap:16px;flex-wrap:wrap;font-size:0.85rem;color:rgba(255,255,255,0.7);">
        <span>📅 {session.data.date}</span>
        <span>👤 {session.data.author}</span>
      </div>
      <div style="display:flex;gap:8px;flex-wrap:wrap;margin-top:14px;">
        {session.data.tags.map(tag => (
          <span style="padding:4px 12px;background:rgba(255,255,255,0.15);border-radius:20px;font-size:0.78rem;color:#fff;backdrop-filter:blur(4px);">{tag}</span>
        ))}
      </div>
    </div>

    <!-- Content -->
    <article class="session-content" style="max-width:800px;">
      <Content />
    </article>

    <!-- Bottom nav -->
    <div style="margin-top:48px;padding-top:24px;border-top:1px solid var(--border);display:flex;justify-content:space-between;align-items:center;">
      <a href="/sessions" style="color:var(--accent);text-decoration:none;font-size:0.9rem;">← All Sessions</a>
      <a href="/feed" style="color:var(--accent);text-decoration:none;font-size:0.9rem;">Latest Feed →</a>
    </div>

  </section>
</main>

<style>
  .session-content :global(h2) {
    font-size: 1.3rem;
    font-weight: 700;
    color: var(--text);
    margin: 32px 0 12px;
    padding-bottom: 8px;
    border-bottom: 1px solid var(--border);
  }
  .session-content :global(h3) {
    font-size: 1.05rem;
    font-weight: 600;
    color: var(--text);
    margin: 24px 0 8px;
  }
  .session-content :global(p) {
    color: var(--text-muted);
    line-height: 1.7;
    margin: 0 0 16px;
  }
  .session-content :global(ul), .session-content :global(ol) {
    color: var(--text-muted);
    padding-left: 24px;
    margin: 0 0 16px;
  }
  .session-content :global(li) {
    margin: 8px 0;
    line-height: 1.6;
  }
  .session-content :global(code) {
    background: var(--surface);
    padding: 2px 6px;
    border-radius: 4px;
    font-size: 0.88em;
    color: var(--accent);
  }
  .session-content :global(pre) {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 16px;
    overflow-x: auto;
    margin: 0 0 16px;
  }
  .session-content :global(pre code) {
    background: none;
    padding: 0;
    color: var(--text);
  }
  .session-content :global(a) {
    color: var(--accent);
    text-decoration: none;
  }
  .session-content :global(a:hover) {
    text-decoration: underline;
  }
  .session-content :global(strong) {
    color: var(--text);
    font-weight: 600;
  }
  .session-content :global(blockquote) {
    border-left: 3px solid var(--accent);
    padding: 12px 16px;
    margin: 0 0 16px;
    background: var(--surface);
    border-radius: 0 var(--radius) var(--radius) 0;
    color: var(--text-muted);
  }
</style>

</BaseLayout>
